{
	"name": "demo-merchant",
	"description": "Jimporium demo storefront and UCP 2026-04-08 merchant service",
	"dependencies": {
		"hono": "^4.12.29",
		"jose": "^6.2.3",
		"react": "19.2.1",
		"react-dom": "19.2.1"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.44.0",
		"@eslint/js": "9.39.1",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"tsx": "^4.23.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"vite": "^6.0.0",
		"wrangler": "^4.110.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "vite",
		"lint": "eslint .",
		"test": "npm run test:payment",
		"test:payment": "tsx tests/paze-verifier.test.ts",
		"preview": "npm run build && vite preview",
		"validate": "npm run build && npm run lint -- --quiet && npm test"
	},
	"type": "module"
}
